// KARINEX digital fulfillment – Prisma schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Shopify session storage (required by the app template) ---
model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)

  refreshToken        String?
  refreshTokenExpires DateTime?
}

// --- Domain enums ---
enum DeliveryType {
  KEY
  FILE
  BOTH
}

enum KeyStatus {
  AVAILABLE
  ASSIGNED
}

enum DeliveryStatus {
  PENDING
  DELIVERED
  FAILED
}

// --- Per-shop settings (one row per installed shop, keyed by shop domain) ---
// Branding + e-mail template customisation, edited under /app/settings.
model AppSettings {
  shop          String   @id
  shopName      String   @default("KARINEX")
  brandColor    String   @default("#0b3d2e")
  logoUrl       String?
  supportEmail  String   @default("kundenservice@karinex.de")
  emailIntro    String?
  emailFooter   String?
  defaultLocale String   @default("de")
  // Admin UI language (chosen on first run) + whether onboarding is done.
  adminLocale   String   @default("de")
  onboarded     Boolean  @default(false)
  // Deliver immediately when an order is *created* (e.g. Vorkasse / bank
  // transfer, before payment is confirmed) instead of only on payment.
  deliverUnpaidOrders Boolean @default(false)
  updatedAt     DateTime @updatedAt @default(now())
}

// --- App data ---
model Product {
  id               String       @id @default(cuid())
  // Owning shop domain (e.g. "my-store.myshopify.com"). Every query is scoped
  // by this so multiple installed shops never see each other's data.
  shop             String
  shopifyProductId String
  title            String
  imageUrl         String?
  productType      String?
  vendor           String?
  deliveryType     DeliveryType @default(KEY)
  downloadLimit    Int          @default(3)
  linkExpiryHours  Int          @default(72)
  // Deliver this product already on order creation (Vorkasse / unpaid),
  // overriding the global setting for this product.
  deliverUnpaid    Boolean      @default(false)
  // Optional per-product instructions shown to the customer (and e-mailed)
  // alongside the key/downloads, e.g. installation notes ("Anleitung").
  deliveryMessage  String?
  createdAt        DateTime     @default(now())

  licenseKeys LicenseKey[]
  files       DigitalFile[]
  links       ProductLink[]
  deliveries  Delivery[]

  // A Shopify product maps to exactly one row per shop.
  @@unique([shop, shopifyProductId])
  @@index([shop])
}

// Static download links shown to every customer who buys the product
// (e.g. a hosted installer / instructions URL). Unlike DigitalFile these
// require no object storage – the merchant just pastes a URL.
model ProductLink {
  id        String   @id @default(cuid())
  productId String
  label     String
  version   String?
  url       String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model LicenseKey {
  id              String    @id @default(cuid())
  productId       String
  keyValue        String
  status          KeyStatus @default(AVAILABLE)
  assignedOrderId String?
  assignedAt      DateTime?

  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  delivery Delivery?

  // Scope uniqueness to the product (which is itself shop-scoped) so the same
  // key string can exist for different shops/products.
  @@unique([productId, keyValue])
  @@index([productId, status])
}

model DigitalFile {
  id         String   @id @default(cuid())
  productId  String
  fileName   String
  storageKey String
  sizeBytes  BigInt   @default(0)
  createdAt  DateTime @default(now())

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  tokens  DownloadToken[]

  @@index([productId])
}

model Delivery {
  id               String         @id @default(cuid())
  // Owning shop domain – scopes every delivery query per installed shop.
  shop             String
  shopifyOrderId   String
  shopifyOrderName String
  customerEmail    String
  productId        String
  licenseKeyId     String?        @unique
  status           DeliveryStatus @default(PENDING)
  errorMessage     String?
  // Random token for the public, shareable delivery page (/delivery/:token).
  accessToken      String?        @unique
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  product    Product         @relation(fields: [productId], references: [id])
  licenseKey LicenseKey?     @relation(fields: [licenseKeyId], references: [id])
  tokens     DownloadToken[]

  // Idempotency: one delivery per shop + order + product.
  @@unique([shop, shopifyOrderId, productId])
  @@index([shop])
  @@index([shopifyOrderId])
  @@index([status])
}

model DownloadToken {
  id            String   @id @default(cuid())
  deliveryId    String
  fileId        String
  token         String   @unique
  expiresAt     DateTime
  maxDownloads  Int      @default(3)
  downloadCount Int      @default(0)
  revoked       Boolean  @default(false)
  createdAt     DateTime @default(now())

  delivery Delivery    @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  file     DigitalFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
}
